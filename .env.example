# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
# or use other LLM providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Model Configuration ───────────────────────────────────────────────────────
# OPENAI_LOOP_MODEL: modelo usado en el ReAct loop (reasoning + selección de tools)
# OPENAI_DATA_MODEL: modelo usado por DatabaseTool para generación de SQL complejo
# Defaults: gpt-5.4-mini / gpt-5.4 — ajustar según disponibilidad y costo
OPENAI_LOOP_MODEL=gpt-5.4-mini
OPENAI_DATA_MODEL=gpt-5.4

# ── Base de datos principal "core" ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_INSTANCE=SQLEXPRESS
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
# Options: mssql, sqlserver, postgresql, mysql, sqlite
DB_TYPE=mssql

# ── Conexiones adicionales (DB-37 multi-database) ─────────────────────────────
# Lista de aliases activos separados por coma. "core" siempre está disponible.
# Ejemplo: DB_CONNECTIONS=core,ventas,rrhh
DB_CONNECTIONS=core

# Para cada alias adicional, definir sus variables con prefijo DB_<ALIAS>_:
# DB_VENTAS_HOST=192.168.1.50
# DB_VENTAS_PORT=1433
# DB_VENTAS_INSTANCE=
# DB_VENTAS_NAME=ventas_db
# DB_VENTAS_USER=ventas_user
# DB_VENTAS_PASSWORD=secret
# DB_VENTAS_TYPE=mssql

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
